EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
# Google Maps — iOS key: restrict to iOS Bundle ID io.pingo.app + Places API (New)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_IOS=xxxx
# Google Maps — Android key: restrict to package io.pingo.app + Maps SDK for Android + Places API (New)
# TODO: once app is on Play Store, add SHA-1 fingerprint restriction to this key in Google Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_ANDROID=xxxx

# Sign in with Google (OAuth client IDs from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.xxxx

# Sentry — DSN en Sentry Dashboard > Project Settings > Client Keys
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
# Sentry Auth Token — solo usado en EAS Build para subir source maps
# Generar en https://sentry.io/settings/account/api/auth-tokens/
# Scopes necesarios: project:releases, org:read
# Guardar en EAS Secrets: eas secret:create --scope project --name SENTRY_AUTH_TOKEN --value sntrys_xxxx
SENTRY_AUTH_TOKEN=sntrys_xxxx

# RevenueCat — iOS Public SDK Key (RC Dashboard > Project > API Keys > Public app-specific)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxxxxxx
# RevenueCat — Android Public SDK Key (RC Dashboard > Project > API Keys > Public app-specific)
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxx
# RevenueCat — Webhook secret: configurar como Supabase secret, NO en .env
# supabase secrets set REVENUECAT_WEBHOOK_AUTH_HEADER="Bearer <token-generado>"
